{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/app/about/*": [
        "./app/(site)/about/*"
      ],
      "@/app/auth/*": [
        "./app/(site)/auth/*"
      ],
      "@/app/contact/*": [
        "./app/(site)/contact/*"
      ],
      "@/app/contacto/*": [
        "./app/(site)/contacto/*"
      ],
      "@/app/coupons/*": [
        "./app/(site)/coupons/*"
      ],
      "@/app/cupones/*": [
        "./app/(site)/cupones/*"
      ],
      "@/app/dashboard/*": [
        "./app/(site)/dashboard/*"
      ],
      "@/app/home/*": [
        "./app/(site)/home/*"
      ],
      "@/app/iglesias/*": [
        "./app/(site)/iglesias/*"
      ],
      "@/app/legal/*": [
        "./app/(site)/legal/*"
      ],
      "@/app/login/*": [
        "./app/(site)/login/*"
      ],
      "@/app/magazine/*": [
        "./app/(site)/magazine/*"
      ],
      "@/app/noticias/*": [
        "./app/(site)/noticias/*"
      ],
      "@/app/publicar/*": [
        "./app/(site)/publicar/*"
      ],
      "@/app/servicios/*": [
        "./app/(site)/servicios/*"
      ],
      "@/app/tienda/*": [
        "./app/(site)/tienda/*"
      ],
      "@/app/clasificados/*": [
        "./app/(site)/clasificados/*"
      ],
      "@/app/admin/*": [
        "./app/admin/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
