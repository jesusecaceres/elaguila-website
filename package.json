{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/next-build.js",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "lint:br": "eslint \"app/(site)/clasificados/bienes-raices/**/*.{ts,tsx}\" \"app/(site)/clasificados/lib/leonix*.ts\" \"app/(site)/clasificados/lib/publish/**/*.{ts,tsx}\" \"app/(site)/clasificados/publicar/bienes-raices/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:servicios": "eslint \"app/(site)/clasificados/servicios/**/*.{ts,tsx}\" \"app/(site)/clasificados/publicar/servicios/**/*.{ts,tsx}\" \"app/(site)/servicios/**/*.{ts,tsx}\" \"app/api/clasificados/servicios/**/*.{ts,tsx}\" \"e2e/**/*.ts\" --max-warnings 0",
    "verify:br": "npx tsx scripts/br-launch-selftest.ts",
    "verify:br:catalog-smoke": "npx tsx scripts/br-supabase-anon-smoke.ts",
    "verify:br:auth-smoke": "npx tsx scripts/br-authenticated-smoke.ts",
    "verify:br:auth-smoke:cleanup": "npx tsx scripts/br-smoke-cleanup.ts",
    "verify:br:launch-gate": "npm run typecheck && npm run lint:br && npm run verify:br",
    "prebuild": "node scripts/dup-guard.js",
    "dup:guard": "node scripts/dup-guard.js",
    "autos:enforce-smoke": "npx tsx scripts/autos-enforcement-smoke.ts",
    "verify:viajes": "node scripts/verify-viajes-pipeline.mjs",
    "verify:viajes:filters": "npx tsx scripts/viajes-browse-filter-selftest.ts",
    "verify:empleos": "npx tsx scripts/empleos-jobposting-schema-selftest.ts",
    "verify:empleos:http-smoke": "node scripts/empleos-http-smoke.mjs",
    "verify:empleos:db-read": "npx tsx scripts/empleos-supabase-read-smoke.mts",
    "verify:restaurantes": "npm run verify:restaurantes:launch",
    "verify:restaurantes:http-smoke": "node scripts/restaurantes-http-smoke.mjs",
    "verify:restaurantes:selftest": "npx tsx scripts/restaurantes-launch-selftest.ts",
    "verify:restaurantes:selftest:logic": "npx tsx scripts/restaurantes-launch-selftest.ts -- --logic-only",
    "verify:restaurantes:e2e": "npx playwright test --config playwright.restaurantes.config.mjs",
    "verify:en-venta": "npx tsx scripts/en-venta-go-live-selftest.ts",
    "verify:en-venta:e2e": "npx playwright test e2e/en-venta-smoke.spec.ts e2e/en-venta-seeded-trace.spec.ts",
    "verify:restaurantes:launch": "npm run typecheck && npm run build && node scripts/restaurantes-http-smoke.mjs && npm run verify:restaurantes:selftest:logic",
    "verify:restaurantes:launch:full": "npm run typecheck && npm run build && node scripts/restaurantes-http-smoke.mjs && npm run verify:restaurantes:selftest",
    "verify:servicios:unit": "npx tsx scripts/serviciosLaunchProof.ts",
    "verify:servicios:http-smoke": "node scripts/servicios-http-smoke.mjs",
    "verify:servicios:e2e": "npx playwright test",
    "verify:servicios": "npm run typecheck && npm run lint:servicios && npm run build && npm run verify:servicios:unit && npm run verify:servicios:http-smoke && npm run verify:servicios:e2e",
    "verify:rentas": "npx tsx scripts/rentas-launch-selftest.ts && npx tsx scripts/rentas-field-contract-selftest.ts",
    "verify:rentas:e2e": "npx tsx scripts/rentas-e2e-pipeline-smoke.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mux/mux-node": "^12.8.1",
    "@supabase/supabase-js": "^2.90.1",
    "@vercel/blob": "^2.3.2",
    "browser-image-compression": "^2.0.2",
    "framer-motion": "^12.23.24",
    "googleapis": "^166.0.0",
    "hls.js": "^1.6.15",
    "html-to-image": "^1.11.13",
    "next": "^15.5.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "rss-parser": "^3.13.0",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
    "eslint-config-next": "^15.0.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
