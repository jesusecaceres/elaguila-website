{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/next-build.js",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "lint:br": "eslint \"app/(site)/clasificados/bienes-raices/**/*.{ts,tsx}\" \"app/(site)/clasificados/lib/leonix*.ts\" \"app/(site)/clasificados/lib/publish/**/*.{ts,tsx}\" \"app/(site)/clasificados/publicar/bienes-raices/**/*.{ts,tsx}\" --max-warnings 0",
    "verify:br": "npx tsx scripts/br-launch-selftest.ts",
    "prebuild": "node scripts/dup-guard.js",
    "dup:guard": "node scripts/dup-guard.js",
    "autos:enforce-smoke": "npx tsx scripts/autos-enforcement-smoke.ts",
    "verify:viajes": "node scripts/verify-viajes-pipeline.mjs",
    "verify:viajes:filters": "npx tsx scripts/viajes-browse-filter-selftest.ts",
    "verify:empleos": "npx tsx scripts/empleos-jobposting-schema-selftest.ts",
    "verify:restaurantes:http-smoke": "node scripts/restaurantes-http-smoke.mjs",
    "verify:en-venta": "npx tsx scripts/en-venta-go-live-selftest.ts",
    "verify:restaurantes:launch": "npm run typecheck && npm run build && node scripts/restaurantes-http-smoke.mjs",
    "verify:servicios": "npx tsx scripts/serviciosLaunchProof.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mux/mux-node": "^12.8.1",
    "@supabase/supabase-js": "^2.90.1",
    "@vercel/blob": "^2.3.2",
    "browser-image-compression": "^2.0.2",
    "framer-motion": "^12.23.24",
    "googleapis": "^166.0.0",
    "hls.js": "^1.6.15",
    "html-to-image": "^1.11.13",
    "next": "^15.5.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "rss-parser": "^3.13.0",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
    "eslint-config-next": "^15.0.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
